# ==============================================================================
# SMC-Office V4.8.3 - Umgebungsvariablen (TEMPLATE)
# ==============================================================================
#
# ACHTUNG: Diese Datei enthält KEINE echten Secrets!
#          In Produktion werden alle Secrets über Infisical injiziert.
#
# Infisical-Pfad: /smc-office/production
# ==============================================================================

# -------------------- DATENBANK --------------------
# PostgreSQL Connection String
# Infisical Key: DATABASE_URL
DATABASE_URL="postgresql://smc_user:PLACEHOLDER@postgres:5432/smc_office_prod"

# -------------------- AUTHENTIFIZIERUNG --------------------
# NextAuth.js Secret (min. 32 Zeichen)
# Infisical Key: NEXTAUTH_SECRET
NEXTAUTH_SECRET="PLACEHOLDER_WIRD_VON_INFISICAL_INJIZIERT"

# Öffentliche URL der Anwendung
# Infisical Key: NEXTAUTH_URL
NEXTAUTH_URL="https://smc-office.eu"

# -------------------- S3/MINIO STORAGE --------------------
# Infisical Keys: S3_ENDPOINT, S3_BUCKET_NAME, S3_ACCESS_KEY, S3_SECRET_KEY
S3_ENDPOINT="http://minio:9000"
S3_BUCKET_NAME="smc-uploads"
S3_ACCESS_KEY="PLACEHOLDER"
S3_SECRET_KEY="PLACEHOLDER"

# -------------------- KALENDER (CalDAV) --------------------
# Infisical Key: CALDAV_ENCRYPTION_KEY
CALDAV_ENCRYPTION_KEY="PLACEHOLDER_32_ZEICHEN"

# -------------------- ABACUS AI (optional) --------------------
# Nur für LLM-Features benötigt
# Infisical Key: ABACUSAI_API_KEY
ABACUSAI_API_KEY="PLACEHOLDER"

# -------------------- N8N INTEGRATION --------------------
# Infisical Key: N8N_API_KEY
N8N_API_KEY="PLACEHOLDER"

# ==============================================================================
# INFISICAL KONFIGURATION (Container-Umgebungsvariablen)
# ==============================================================================
# Diese Werte werden als Docker-Environment gesetzt, NICHT in .env:
#
# INFISICAL_TOKEN=st.xxxx...           # Service Token
# INFISICAL_PROJECT_ID=smc-office      # Projekt-ID
# INFISICAL_ENVIRONMENT=production     # Environment (production/staging)
# ==============================================================================
